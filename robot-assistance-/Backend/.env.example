# MongoDB Atlas (required for DB endpoints)
MONGODB_URI=
MONGODB_DB_NAME=humoid
MONGODB_TIMEOUT_MS=5000
# Example Atlas URI:
# MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<app>

# Google Calendar OAuth / Service Account (either mode)
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_OAUTH_CLIENT_FILE=./credentials/google-oauth-client.json
GOOGLE_OAUTH_TOKEN_FILE=./credentials/google-token.json
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Asia/Kolkata

# Weather provider: openweather | google
WEATHER_PROVIDER=openweather
WEATHER_API_KEY=
WEATHER_BASE_URL=https://api.openweathermap.org/data/2.5
GEOCODING_PROVIDER=
GEOCODING_API_KEY=
OPENCAGE_GEOCODE_URL=https://api.opencagedata.com/geocode/v1/json
GOOGLE_WEATHER_URL=https://weather.googleapis.com/v1/currentConditions:lookup
GOOGLE_GEOCODE_URL=https://maps.googleapis.com/maps/api/geocode/json
